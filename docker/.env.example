# ===========================================
# AI Assistant 配置模板
# 复制为 .env 并填入你的 API Key
# ===========================================

# --- 必填: AI 服务 ---
# DeepSeek API (对话模型) https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 阿里云 DashScope API (文本嵌入 + TTS 语音合成) https://dashscope.aliyun.com
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# --- 可选: 搜索服务 ---
# SearXNG 自部署地址
SEARXNG_BASE_URL=http://searxng:8080

# 搜索引擎备用 API (如果 SearXNG 不可用)
# Bing Search API
BING_SEARCH_API_KEY=
# 或者 SerpAPI
SERPAPI_API_KEY=

# --- 金融数据 ---
# Finnhub API (美股行情/财务/新闻) https://finnhub.io
FINNHUB_API_KEY=your-finnhub-api-key

# --- 数据库连接 ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- ChromaDB ---
# 嵌入式模式，只需指定持久化目录
CHROMA_PERSIST_DIR=/data/chromadb

# --- 服务配置 ---
HOST=0.0.0.0
PORT=8000
# 用于 WebSocket 连接的 API Key 验证 (留空跳过验证)
API_KEY=your-service-api-key

# --- 模型配置 ---
# DeepSeek 模型: deepseek-chat / deepseek-reasoner
CHAT_MODEL=deepseek-chat
# 嵌入模型 (阿里云 DashScope)
EMBEDDING_MODEL=text-embedding-v2

# --- TTS 配置 ---
# TTS 语音合成 (需要 DASHSCOPE_API_KEY)
TTS_ENABLED=true
# 模型: cosyvoice-v3-flash (快) / cosyvoice-v3 (好)
TTS_MODEL=cosyvoice-v3-flash
# 音色: longanyang / longxiaochun / longxiaoxia / longwanqing 等
TTS_VOICE=longanyang
# 采样率: 8000 / 16000 / 22050 / 24000 / 44100 / 48000
TTS_SAMPLE_RATE=24000

# --- 记忆配置 ---
# 检索时返回的最大记忆数量
MEMORY_TOP_K=5
# 短期记忆的对话轮数
SHORT_TERM_TURNS=20
# 对话片段窗口大小（字符数）
CHUNK_SIZE=500
